<%- include('../../partials/header') %>

<div class="admin-layout">
  <%- include('../../partials/admin-sidebar') %>

  <div class="admin-content">
  <!-- replaced above -->
    <h1>Create New Subject</h1>

    <form action="/admin/subjects/create" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label for="title">Title *</label>
        <input type="text" id="title" name="title" required>
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="4"></textarea>
      </div>

      <div class="form-group">
        <label for="coverImage">Cover Image</label>
        <input type="file" id="coverImage" name="coverImage" accept="image/*" onchange="previewCoverImage(this)">
        <div id="imagePreview" style="display: none; margin-top: 16px;">
          <p style="margin-bottom: 8px; color: var(--text-secondary); font-size: 14px;">Preview:</p>
          <img id="previewImg" src="" alt="Preview" style="width: 250px; height: auto; border-radius: 8px; border: 1px solid var(--border-color); box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        </div>
      </div>

      <div class="form-group">
        <label for="visibility">Visibility</label>
        <select id="visibility" name="visibility" onchange="toggleTeamSelect()">
          <option value="public">Public</option>
          <option value="team">Team Only</option>
        </select>
      </div>

      <div class="form-group" id="teamSelectGroup" style="display: none;">
        <label for="teamId">Select Team *</label>
        <select id="teamId" name="teamId">
          <option value="">-- Select Team --</option>
          <% if (locals.isGlobalAdmin) { %>
            <!-- Super admin: will load all teams via API -->
          <% } else if (locals.userTeams && locals.userTeams.length > 0) { %>
            <!-- Team admin: show only their teams -->
            <% userTeams.forEach(team => { %>
              <option value="<%= team.id %>"><%= team.name %></option>
            <% }); %>
          <% } %>
        </select>
      </div>

      <div class="form-group">
        <label for="displayOrder">Display Order</label>
        <input type="number" id="displayOrder" name="displayOrder" value="0">
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" name="isPublished" checked>
          Publish immediately
        </label>
      </div>

      <button type="submit" class="btn btn-primary">Create Subject</button>
      <a href="/admin/subjects" class="btn btn-secondary">Cancel</a>
    </form>
  </div>
</div>

<script>
// Preview cover image
function previewCoverImage(input) {
  const preview = document.getElementById('imagePreview');
  const previewImg = document.getElementById('previewImg');

  if (input.files && input.files[0]) {
    const reader = new FileReader();

    reader.onload = function(e) {
      previewImg.src = e.target.result;
      preview.style.display = 'block';
    };

    reader.readAsDataURL(input.files[0]);
  } else {
    preview.style.display = 'none';
  }
}

// Toggle team selection
function toggleTeamSelect() {
  const visibility = document.getElementById('visibility').value;
  const teamSelectGroup = document.getElementById('teamSelectGroup');
  const teamIdSelect = document.getElementById('teamId');

  if (visibility === 'team') {
    teamSelectGroup.style.display = 'block';
    teamIdSelect.required = true;
    loadTeams();
  } else {
    teamSelectGroup.style.display = 'none';
    teamIdSelect.required = false;
  }
}

// Load teams (only for super admin)
async function loadTeams() {
  <% if (locals.isGlobalAdmin) { %>
  try {
    const response = await fetch('/api/teams');
    const teams = await response.json();
    const select = document.getElementById('teamId');

    select.innerHTML = '<option value="">-- Select Team --</option>';
    teams.forEach(team => {
      const option = document.createElement('option');
      option.value = team.id;
      option.textContent = team.name;
      select.appendChild(option);
    });
  } catch (error) {
    console.error('Failed to load teams:', error);
  }
  <% } %>
  // Team admins already have their teams pre-loaded in the HTML
}
</script>

<%- include('../../partials/footer') %>
