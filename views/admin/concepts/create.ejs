<%- include('../../partials/header') %>

<div class="admin-layout">
  <%- include('../../partials/admin-sidebar') %>

  <div class="admin-content">
    <h1>Create New Concept</h1>

    <form action="/admin/concepts/create" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label for="title">Title *</label>
        <input type="text" id="title" name="title" required>
      </div>

      <div class="form-group">
        <label for="topicId">Topic *</label>
        <select id="topicId" name="topicId" required <%= selectedTopicId ? 'disabled' : '' %>>
          <option value="">Select a topic</option>
          <% topics.forEach(topic => { %>
            <option value="<%= topic.id %>" <%= selectedTopicId === topic.id ? 'selected' : '' %>><%= topic.subject.title %> / <%= topic.title %></option>
          <% }); %>
        </select>
        <% if (selectedTopicId) { %>
          <input type="hidden" name="topicId" value="<%= selectedTopicId %>">
          <small style="color: var(--text-secondary);">Topic is pre-selected and cannot be changed</small>
        <% } %>
      </div>

      <div class="form-group">
        <label for="coverImage">Cover Image</label>
        <input type="file" id="coverImage" name="coverImage" accept="image/*" onchange="previewCoverImage(this)">
        <div id="imagePreview" style="display: none; margin-top: 16px;">
          <p style="margin-bottom: 8px; color: var(--text-secondary); font-size: 14px;">Preview:</p>
          <img id="previewImg" src="" alt="Preview" style="width: 250px; height: auto; border-radius: 8px; border: 1px solid var(--border-color); box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        </div>
      </div>

      <div class="form-group">
        <label for="displayOrder">Display Order</label>
        <input type="number" id="displayOrder" name="displayOrder" value="0">
      </div>

      <div class="form-group">
        <label>Content Type</label>
        <div style="margin-bottom: 16px;">
          <label style="margin-right: 20px;">
            <input type="radio" name="contentType" value="editor" checked onchange="toggleContentType()">
            Rich Text Editor
          </label>
          <label>
            <input type="radio" name="contentType" value="pdf" onchange="toggleContentType()">
            Upload PDF
          </label>
        </div>
      </div>

      <div id="editorSection">
        <div class="form-group">
          <label>Upload HTML/Markdown File (optional)</label>
          <input type="file" id="fileUpload" accept=".html,.md,.markdown" onchange="uploadFile(this, 'editor')">
          <small style="color: var(--text-secondary);">Upload an HTML or Markdown file to import content</small>
        </div>

        <div class="form-group">
          <label for="content">Content</label>
          <div style="margin-bottom: 10px; display: flex; gap: 10px;">
            <button type="button" class="btn btn-secondary" onclick="improveWithAI()" style="font-size: 0.9rem;">
              ✨ Improve with AI
            </button>
            <button type="button" class="btn btn-secondary" onclick="summarizeWithAI()" style="font-size: 0.9rem;">
              📝 Summarize
            </button>
          </div>
          <div id="editor" style="height: 400px;"></div>
          <input type="hidden" id="content" name="content">
        </div>
      </div>

      <div id="pdfSection" style="display: none;">
        <div class="form-group">
          <label for="pdfFile">Upload PDF Document *</label>
          <input type="file" id="pdfFile" name="pdfFile" accept=".pdf">
          <small style="color: var(--text-secondary);">Upload a PDF file (max 50MB). This will be displayed to users in a PDF viewer.</small>
        </div>
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" name="isPublished" checked>
          Publish immediately
        </label>
      </div>

      <button type="submit" class="btn btn-primary">Create Concept</button>
      <a href="/admin/concepts" class="btn btn-secondary">Cancel</a>
    </form>
  </div>
</div>

<%- include('../../partials/footer') %>

<script>
(function() {
  console.log('Script running - Quill library available:', typeof Quill !== 'undefined');
  console.log('Editor element exists:', !!document.getElementById('editor'));

  // Initialize Quill editor after DOM and Quill are loaded
  if (typeof Quill !== 'undefined') {
    window.quillEditor = new Quill('#editor', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
          ['bold', 'italic', 'underline', 'strike'],
          ['blockquote', 'code-block'],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          [{ 'script': 'sub'}, { 'script': 'super' }],
          [{ 'indent': '-1'}, { 'indent': '+1' }],
          [{ 'color': [] }, { 'background': [] }],
          [{ 'align': [] }],
          ['link', 'image'],
          ['clean']
        ]
      }
    });

    console.log('✅ Quill editor initialized:', !!window.quillEditor);

    // Save content on form submit
    const form = document.querySelector('form');
    if (form) {
      form.addEventListener('submit', function(e) {
        console.log('Form submitting...');
        const contentHtml = window.quillEditor.root.innerHTML;
        const hiddenField = document.getElementById('content');
        hiddenField.value = contentHtml;
        console.log('✅ Content saved to hidden field, length:', contentHtml.length);
        console.log('Hidden field value length:', hiddenField.value.length);
      });
      console.log('✅ Form submit listener attached');
    }
  } else {
    console.error('❌ Quill library not loaded!');
  }
})();

// Toggle between editor and PDF upload
function toggleContentType() {
  const contentType = document.querySelector('input[name="contentType"]:checked').value;
  const editorSection = document.getElementById('editorSection');
  const pdfSection = document.getElementById('pdfSection');

  if (contentType === 'pdf') {
    editorSection.style.display = 'none';
    pdfSection.style.display = 'block';
  } else {
    editorSection.style.display = 'block';
    pdfSection.style.display = 'none';
  }
}

// Preview cover image
function previewCoverImage(input) {
  const preview = document.getElementById('imagePreview');
  const previewImg = document.getElementById('previewImg');

  if (input.files && input.files[0]) {
    const reader = new FileReader();

    reader.onload = function(e) {
      previewImg.src = e.target.result;
      preview.style.display = 'block';
    };

    reader.readAsDataURL(input.files[0]);
  } else {
    preview.style.display = 'none';
  }
}

// AI Improve Content
async function improveWithAI() {
  if (!window.quillEditor) {
    showToast('Editor not initialized', 'error');
    return;
  }

  const currentContent = window.quillEditor.root.innerHTML;
  if (!currentContent || currentContent.trim() === '<p><br></p>') {
    showToast('Please add some content first', 'error');
    return;
  }

  const btn = event.target;
  const originalText = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '⏳ Improving...';

  try {
    const response = await fetch('/admin/ai-improve', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content: currentContent })
    });

    const data = await response.json();

    if (data.success && data.improvedContent) {
      window.quillEditor.root.innerHTML = data.improvedContent;
      showToast('Content improved successfully!', 'success');
    } else {
      showToast(data.error || 'Failed to improve content', 'error');
    }
  } catch (error) {
    console.error('AI improve error:', error);
    showToast('Failed to improve content: ' + error.message, 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = originalText;
  }
}

// AI Summarize Content
async function summarizeWithAI() {
  if (!window.quillEditor) {
    showToast('Editor not initialized', 'error');
    return;
  }

  const currentContent = window.quillEditor.root.innerHTML;
  if (!currentContent || currentContent.trim() === '<p><br></p>') {
    showToast('Please add some content first', 'error');
    return;
  }

  const btn = event.target;
  const originalText = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '⏳ Summarizing...';

  try {
    const response = await fetch('/admin/ai-summarize', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content: currentContent })
    });

    const data = await response.json();

    if (data.success && data.summary) {
      // Insert summary at the beginning
      const summaryHtml = `<blockquote><strong>Summary:</strong> ${data.summary}</blockquote>`;
      window.quillEditor.root.innerHTML = summaryHtml + currentContent;
      showToast('Summary added!', 'success');
    } else {
      showToast(data.error || 'Failed to generate summary', 'error');
    }
  } catch (error) {
    console.error('AI summarize error:', error);
    showToast('Failed to summarize: ' + error.message, 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = originalText;
  }
}
</script>
